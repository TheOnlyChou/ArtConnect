<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search artworks..." HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="statusFilter" promptText="Status" />
        <ComboBox fx:id="artistFilter" promptText="Artist" />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
    </HBox>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="titleInput" promptText="Title" prefWidth="180" />
        <TextField fx:id="creationYearInput" promptText="Year" prefWidth="80" />
        <TextField fx:id="typeInput" promptText="Type" prefWidth="120" />
        <TextField fx:id="mediumInput" promptText="Medium" prefWidth="120" />
        <TextField fx:id="dimensionsInput" promptText="Dimensions" prefWidth="120" />
        <TextField fx:id="priceInput" promptText="Price" prefWidth="90" />
        <ComboBox fx:id="statusInput" promptText="Status" prefWidth="120" />
        <ComboBox fx:id="artistInput" promptText="Artist" prefWidth="180" />
        <TextField fx:id="tagsInput" promptText="Tags (comma-separated)" prefWidth="200" />
    </HBox>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextArea fx:id="descriptionInput" promptText="Description" prefRowCount="2" prefWidth="360" />
        <Button text="Add" onAction="#handleAddArtwork" />
        <Button text="Update" onAction="#handleUpdateArtwork" />
        <Button text="Delete" onAction="#handleDeleteArtwork" />
        <Button text="Clear" onAction="#handleClearForm" />
    </HBox>
    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="180" />
            <TableColumn fx:id="artistColumn" text="Artist" prefWidth="150" />
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="110" />
            <TableColumn fx:id="yearColumn" text="Year" prefWidth="80" />
            <TableColumn fx:id="dimensionsColumn" text="Dimensions" prefWidth="120" />
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="90" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120" />
            <TableColumn fx:id="tagsColumn" text="Tags" prefWidth="200" />
            <TableColumn fx:id="descriptionPreviewColumn" text="Description" prefWidth="220" />
        </columns>
    </TableView>
</VBox>
