<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <GridPane hgap="8.0" vgap="8.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="15" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="15" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="20" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="30" />
            <RowConstraints minHeight="30" />
            <RowConstraints minHeight="30" />
        </rowConstraints>

        <Label text="Title:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="titleInput" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Artist:" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <ComboBox fx:id="artistCombo" GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="Type:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="typeInput" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Year:" GridPane.rowIndex="1" GridPane.columnIndex="2" />
        <TextField fx:id="yearInput" GridPane.rowIndex="1" GridPane.columnIndex="3" />

        <Label text="Price:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <TextField fx:id="priceInput" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="Status:" GridPane.rowIndex="2" GridPane.columnIndex="2" />
        <ComboBox fx:id="statusCombo" GridPane.rowIndex="2" GridPane.columnIndex="3" />
    </GridPane>

    <HBox spacing="8.0">
        <Button text="Add" onAction="#handleAddArtwork" />
        <Button text="Update" onAction="#handleUpdateArtwork" />
        <Button text="Delete" onAction="#handleDeleteArtwork" />
        <Button text="Clear" onAction="#handleClearForm" />
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" promptText="Search (title, artist, type)..." />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
    </HBox>

    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="artistColumn" text="Artist" prefWidth="150" />
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100" />
            <TableColumn fx:id="yearColumn" text="Year" prefWidth="80" />
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="100" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="150" />
        </columns>
    </TableView>
</VBox>
